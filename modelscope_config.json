{
  "name": "medevidence-ai",
  "display_name": "医学循证检索助手",
  "description": "基于KnowS医学循证API的智能检索工具，支持PubMed文献检索、循证分级标注、智能摘要生成。帮助医生、医学生快速获取高质量医学证据。",
  "icon": "🩺",
  "category": "medical",
  "source": {
    "type": "github",
