# MedEvidence AI 环境变量配置
# 复制此文件为 .env 并填入实际的API密钥

# =====================================
# KnowS API 配置
# 申请地址：https://developers.nullht.com/
# =====================================
KNOWS_API_KEY=your_knows_api_key_here
KNOWS_API_BASE=https://api.nullht.com/v1

# =====================================
# 阶跃星辰 StepFun API 配置
# 申请地址：https://platform.stepfun.com/
# =====================================
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_API_BASE=https://api.stepfun.com/v1
STEPFUN_MODEL=step-2-16k  # 可用: step-1-8k, step-1-32k, step-2-16k, step-2-mini, step-3.5-flash

# =====================================
# 应用配置
# =====================================
APP_NAME=MedEvidence AI
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600  # 秒

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# 日志级别
LOG_LEVEL=INFO
